{
  "name": "@absolutejs/onchain",
  "version": "0.1.2",
  "homepage": "https://github.com/absolutejs/onchain",
  "bugs": {
    "url": "https://github.com/absolutejs/onchain/issues"
  },
  "description": "Gasless collectible provenance for AbsoluteJS apps: attested minting, literal editions, immutable origin ownership, and marketplace-controlled transfers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapter-kit": {
      "types": "./dist/adapter-kit/index.d.ts",
      "import": "./dist/adapter-kit/index.js",
      "default": "./dist/adapter-kit/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./manifest.json": "./dist/manifest.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts src/adapter-kit/index.ts src/manifest.ts --root ./src --outdir dist --sourcemap --target=bun && tsc --project tsconfig.build.json && absolute-manifest emit",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "absolutejs",
    "blockchain",
    "onchain",
    "nft",
    "soulbound",
    "provenance",
    "collectibles"
  ],
  "license": "BSL-1.1",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@absolutejs/manifest": "^0.4.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "absolutejs": {
    "manifestContract": 2
  }
}
